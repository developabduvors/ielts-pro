# Single app (apps/web): student at "/", admin at "/admin".
# Copy this file to .env.local at the repo root and fill in real values.
# .env.local is gitignored — never commit real keys.

# --- Supabase (client + server) ---
NEXT_PUBLIC_SUPABASE_URL=https://nmwtpcbczurxrxcgpxyn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Server-only. Never expose in the browser. Rotate if leaked.
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# --- Auth sessions (two independent cookie secrets, strong random strings) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STUDENT_SESSION_SECRET=replace-with-strong-random-string
ADMIN_SESSION_SECRET=replace-with-strong-random-string

# Comma-separated admin emails allowed into /admin
ADMIN_EMAILS=miravzalsalakhiddinov@gmail.com
