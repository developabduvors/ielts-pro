{
  "name": "ielts-pro-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "build:vercel": "npm run build:vercel --workspace web",
    "start": "npm run start --workspace web",
    "test:smoke": "node scripts/qa-smoke.mjs",
    "typecheck": "npm --workspaces run typecheck --if-present",
    "lint": "npm --workspaces run lint --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.40",
    "dotenv": "^17.4.2"
  }
}
