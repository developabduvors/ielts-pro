{
  "name": "ielts-pro-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:student": "npm run dev --workspace student-web",
    "dev:admin": "npm run dev --workspace admin-web",
    "build": "npm run build:student && npm run build:admin",
    "build:student": "npm run build --workspace student-web",
    "build:admin": "npm run build --workspace admin-web",
    "test:smoke": "node scripts/qa-smoke.mjs",
    "typecheck": "npm --workspaces run typecheck --if-present",
    "lint": "npm --workspaces run lint --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.40"
  }
}
